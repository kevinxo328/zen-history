{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.agents/hooks/post-edit.sh",
            "timeout": 60,
            "statusMessage": "Running format, lint, and type-check..."
          }
        ]
      }
    ]
  }
}
