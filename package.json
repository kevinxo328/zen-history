{
  "name": "zen-history",
  "description": "Let go of what you no longer need. Clean your browsing history with clarity and calm.",
  "private": true,
  "version": "0.1.1",
  "author": "kevinxo328",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "vitest run && pnpm type-check",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "postinstall": "wxt prepare",
    "clean": "rimraf .wxt dist"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@vueuse/core": "^13.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.532.0",
    "pinia": "^3.0.3",
    "reka-ui": "^2.4.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.3.6",
    "vue": "^3.5.13",
    "vue-i18n": "^11.1.11"
  },
  "devDependencies": {
    "@intlify/unplugin-vue-i18n": "^6.0.8",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@wxt-dev/module-vue": "^1.0.2",
    "eslint": "^10.0.3",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "6.0.2",
    "vite-plugin-package-version": "^1.1.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.6",
    "wxt": "^0.20.20"
  },
  "packageManager": "pnpm@10.13.1+sha1.aa8c167c4509c97519542ef77a09e4b8ab59fb6a",
  "engines": {
    "node": ">=20.0.0"
  }
}
